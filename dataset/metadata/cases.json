{
  "version": "v1",
  "description": "Small practical evaluation set for multi-model 3D generation comparison.",
  "groups": {
    "main_image_set": {
      "goal": "Shared image-conditioned baseline for fair cross-model comparison.",
      "size": 4
    },
    "text_extension_set": {
      "goal": "Small text-conditioned extension for models with strong text-to-3D path.",
      "size": 2
    },
    "challenge_set": {
      "goal": "Failure-analysis subset focused on hard materials and structures.",
      "size": 2
    }
  },
  "cases": [
    {
      "case_id": "img_robot",
      "type": "image",
      "input_path": "dataset/images/robot.png",
      "group": "main_image_set",
      "category": "character_object",
      "intended_models": ["triposr", "instantmesh", "hunyuan3d", "trellis"]
    },
    {
      "case_id": "img_chair",
      "type": "image",
      "input_path": "dataset/images/chair.png",
      "group": "main_image_set",
      "category": "furniture",
